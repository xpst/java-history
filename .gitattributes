# Normalize all text files to LF on checkout and in the repo.
* text=auto eol=lf

# Explicit text + LF for source/config files (defensive).
*.java       text eol=lf
*.kt         text eol=lf
*.xml        text eol=lf
*.properties text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf
*.json       text eol=lf
*.md         text eol=lf
*.txt        text eol=lf
*.html       text eol=lf
*.css        text eol=lf
*.js         text eol=lf
*.jsx        text eol=lf
*.ts         text eol=lf
*.tsx        text eol=lf
*.sh         text eol=lf
*.gitignore  text eol=lf
*.gitattributes text eol=lf

# Windows-only scripts keep CRLF.
*.bat        text eol=crlf
*.cmd        text eol=crlf
*.ps1        text eol=crlf

# Binary — never touch line endings.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.pdf  binary
*.zip  binary
*.jar  binary
*.war  binary
*.class binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.otf  binary
